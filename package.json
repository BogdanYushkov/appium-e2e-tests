{
  "name": "mobileautotests",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "wdio run wdio.conf.ts",
    "test:smoke": "wdio run wdio.conf.ts --suite smoke",
    "test:login": "wdio run wdio.conf.ts --suite login",
    "test:navigation": "wdio run wdio.conf.ts --suite navigation",
    "test:form": "wdio run wdio.conf.ts --suite form",
    "test:negative": "wdio run wdio.conf.ts --suite negative",
    "allure:generate": "allure generate reports/allure-results --clean -o reports/allure-report",
    "allure:open": "allure open reports/allure-report",
    "allure:serve": "allure serve reports/allure-results",
    "allure:report": "npm run allure:generate && npm run allure:open",
    "clean": "rimraf reports dist allure-results allure-report",
    "clean:reports": "rimraf reports",
    "appium:start": "appium --relaxed-security"
  },
  "keywords": ["mobile", "automation", "appium", "webdriverio", "android"],
  "author": "",
  "license": "ISC",
  "description": "Mobile automation framework with WebdriverIO, Appium 2.x, TypeScript",
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.9.0",
    "@wdio/allure-reporter": "^9.27.1",
    "@wdio/appium-service": "^9.27.1",
    "@wdio/cli": "^9.27.1",
    "@wdio/local-runner": "^9.27.1",
    "@wdio/mocha-framework": "^9.27.1",
    "@wdio/spec-reporter": "^9.27.1",
    "allure-commandline": "^2.41.0",
    "fs-extra": "^11.3.5",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "webdriverio": "^9.27.1",
    "winston": "^3.19.0"
  }
}
